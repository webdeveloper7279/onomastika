# ── Onomastika backend muhit o'zgaruvchilari ──
# Bu faylni nusxalab `.env` deb saqlang va qiymatlarni to'ldiring.

# Server porti (Render avtomatik beradi, lokalda 5000)
PORT=5000

# Ma'lumotlar ombori (PostgreSQL ulanish satri).
# Render'da Postgres yaratganingizda "Internal Database URL" ni shu yerga qo'ying.
# Bo'sh qoldirsangiz, lokal sinov uchun backend/data/db.json fayliga yozadi.
DATABASE_URL=

# Admin paroli (birinchi ishga tushganda shu paroldan boshlanadi).
ADMIN_PASSWORD=onomastika2025

# Tokenlarni imzolash uchun maxfiy kalit (uzun tasodifiy satr qo'ying!).
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend manzili (CORS uchun). Vergul bilan bir nechta berish mumkin.
# Bo'sh qoldirsangiz hamma manzilga ruxsat beriladi.
CORS_ORIGIN=

# ── Email (ixtiyoriy) ──
# Quyidagilar to'ldirilsa: yangi murojaat kelganda adminga xabar boradi,
# admin javob yozsa foydalanuvchiga email yuboriladi.
# To'ldirilmasa — sayt baribir ishlaydi, murojaatlar admin panelda ko'rinadi.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Xatlar shu manzildan/manzilga yuboriladi:
MAIL_FROM=
ADMIN_EMAIL=xojamurod@list.ru
